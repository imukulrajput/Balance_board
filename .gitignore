# ========================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
MemoryCaptures/
UserSettings/
Logs/
*.csproj
*.unityproj
*.sln
*.pidb
*.userprefs
*.booproj

# Binary & output files
*.apk
*.aab
*.dex
*.so
*.jar
*.dll
*.bin
*.exe
*.pdb
*.mdb

