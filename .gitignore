# ========================
# Android-specific ignores
# ========================
*.iml
.gradle/
local.properties
/.idea/
.DS_Store
/build/
/app/build/
/captures/
/externalNativeBuild/
/.cxx/

# ========================
# UnityLibrary-specific ignores
# ========================
UnityLibrary/build/
UnityLibrary/.gradle/
UnityLibrary/.idea/
UnityLibrary/local.properties
UnityLibrary/.cxx/
UnityLibrary/obj/
UnityLibrary/Temp/
UnityLibrary/Library/
UnityLibrary/Logs/
UnityLibrary/UserSettings/

# Optional: ignore IL2CPP artifacts (if used)
UnityLibrary/il2cpp/

# Optional: ignore asset bundles or temporary data
UnityLibrary/Assets/StreamingAssets/aa.meta
UnityLibrary/Assets/AssetBundles/

# Keep Unity code, assets, scenes, etc.
# Don't ignore UnityLibrary/Assets/**

# ========================
